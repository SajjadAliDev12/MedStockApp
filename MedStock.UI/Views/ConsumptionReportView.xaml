<UserControl x:Class="MedStock.UI.Views.ConsumptionReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FlowDirection="RightToLeft"
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20" Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="1.5*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="15" CornerRadius="8" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <WrapPanel Orientation="Horizontal">
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="من تاريخ" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                        <DatePicker SelectedDate="{Binding FromDate}" Width="110"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="إلى تاريخ" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                        <DatePicker SelectedDate="{Binding ToDate}" Width="110"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="التصنيف" Foreground="Gray" FontSize="11" Margin="0,0,0,3"/>
                        <ComboBox ItemsSource="{Binding Categories}" 
                                  DisplayMemberPath="Name" 
                                  SelectedItem="{Binding SelectedCategory}"
                                  Width="180"/>
                    </StackPanel>

                    <Button Content="عرض التقرير" Command="{Binding SearchCommand}" 
                            Width="100" Height="32" Margin="0,18,10,0" VerticalAlignment="Top"
                            Background="{StaticResource PrimaryBrush}" Foreground="White" FontWeight="Bold"/>
                </WrapPanel>

                <Button Grid.Column="1" Content="تصدير Excel/CSV" Command="{Binding ExportCommand}" 
                        Width="120" Height="32" VerticalAlignment="Bottom"
                        Background="#2E7D32" Foreground="White"/>
            </Grid>
        </Border>

        <GroupBox Grid.Row="1" Header="ملخص استهلاك المواد (اضغط على مادة لعرض تفاصيلها)" Padding="2" BorderBrush="#DDD">
            <DataGrid ItemsSource="{Binding SummaryRows}" SelectedItem="{Binding SelectedSummary}"
                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" 
                      GridLinesVisibility="Horizontal" Background="White">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="كود المادة (SKU)" Binding="{Binding Sku}" Width="120" FontWeight="Bold"/>
                    <DataGridTextColumn Header="اسم المادة" Binding="{Binding ItemName}" Width="*"/>
                    <DataGridTextColumn Header="الوحدة" Binding="{Binding UnitName}" Width="80"/>
                    <DataGridTextColumn Header="إجمالي الكمية" Binding="{Binding TotalQty, StringFormat='{}{0:0.##}'}" Width="120" FontWeight="Bold" Foreground="DarkBlue"/>
                    <DataGridTextColumn Header="عدد الحركات" Binding="{Binding TransactionCount}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="Transparent"/>

        <GroupBox Grid.Row="3" Header="تفاصيل حركات الصرف للمادة المختارة" Padding="2" BorderBrush="#DDD">
            <DataGrid ItemsSource="{Binding DetailRows}"
                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" 
                      GridLinesVisibility="Horizontal" Background="#FAFAFA">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="التاريخ" Binding="{Binding Date, StringFormat='yyyy-MM-dd HH:mm'}" Width="130"/>
                    <DataGridTextColumn Header="رقم السند" Binding="{Binding TransactionNo}" Width="100"/>
                    <DataGridTextColumn Header="القسم المستلم" Binding="{Binding DepartmentName}" Width="150" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="سبب الصرف" Binding="{Binding Reason}" Width="120"/>
                    <DataGridTextColumn Header="الكمية" Binding="{Binding Qty, StringFormat=N0}" Width="80" FontWeight="Bold"/>
                    <DataGridTextColumn Header="الموظف" Binding="{Binding UserName}" Width="100"/>
                    <DataGridTextColumn Header="ملاحظات" Binding="{Binding Notes}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <Border Grid.Row="4" Margin="0,5,0,0" Padding="10" Background="#E3F2FD" CornerRadius="4">
            <DockPanel>
                <TextBlock Text="{Binding StatusMessage}" Foreground="Crimson" FontWeight="Bold" DockPanel.Dock="Right"/>
                <TextBlock Text="{Binding SummaryTotalInfo}" Foreground="{StaticResource PrimaryDarkBrush}" FontWeight="SemiBold"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>