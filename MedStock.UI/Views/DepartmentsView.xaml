<UserControl x:Class="MedStock.UI.Views.DepartmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:MedStock.UI.Resources"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryDarkBrush}"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="0,4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0F2F1"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20" Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Border Width="5" Height="25" Background="{StaticResource PrimaryBrush}" CornerRadius="2" Margin="0,0,10,0"/>
            <TextBlock Text="الأقسام"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryDarkBrush}"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: List -->
            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Direction="270" Opacity="0.5"/>
                </Border.Effect>

                <DockPanel Margin="15">
                    <!-- Top toolbar -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" Height="38"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="{x:Static res:Strings.Search}"
                                 VerticalContentAlignment="Center"
                                 FontSize="14">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>

                        <Button Grid.Column="1" Margin="10,0,0,0" Width="120" Height="38"
                                Content="{x:Static res:Strings.Search}"
                                Command="{Binding RefreshCommand}"
                                Background="{StaticResource PrimaryBrush}"/>

                        <Button Grid.Column="2" Margin="10,0,0,0" Width="120" Height="38"
                                Content="{x:Static res:Strings.Add}"
                                Command="{Binding NewCommand}"
                                Background="{StaticResource SuccessBrush}"/>
                    </Grid>

                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Width="120" Height="36"
                                Content="{x:Static res:Strings.Edit}"
                                Command="{Binding EditCommand}"
                                Background="#0277BD"/>

                        <Button Margin="10,0,0,0" Width="120" Height="36"
                                Content="{x:Static res:Strings.Deactivate}"
                                Command="{Binding ToggleActiveCommand}"
                                Background="{StaticResource DangerBrush}"/>
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding Rows}"
                              SelectedItem="{Binding Selected}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#EEEEEE"
                              HeadersVisibility="Column"
                              BorderThickness="1"
                              BorderBrush="{StaticResource BorderBrush}">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="الكود" Binding="{Binding Code}" Width="140"/>
                            <DataGridTextColumn Header="{x:Static res:Strings.Name}" Binding="{Binding Name}" Width="*"/>

                            <DataGridTemplateColumn Header="{x:Static res:Strings.IsActive}" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding IsActive}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Right: Editor -->
            <Border Grid.Column="2"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#DDDDDD" BlurRadius="10" ShadowDepth="2" Direction="270" Opacity="0.5"/>
                </Border.Effect>

                <StackPanel Margin="20">
                    <TextBlock Text="{x:Static res:Strings.Edit}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="الكود" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                    <TextBox Height="40"
                             Text="{Binding CodeText, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14"/>

                    <TextBlock Text="{x:Static res:Strings.Name}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,5"/>
                    <TextBox Height="40"
                             Text="{Binding NameText, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14"/>

                    <TextBlock Text="ملاحظات" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,5"/>
                    <TextBox Height="90"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalContentAlignment="Top"
                             Text="{Binding NotesText, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14"/>

                    <CheckBox Margin="0,16,0,0"
                              IsChecked="{Binding IsActive}"
                              Content="{x:Static res:Strings.Active}"
                              FontSize="14"
                              VerticalContentAlignment="Center"/>

                    <Button Margin="0,24,0,0" Height="45"
                            Content="{x:Static res:Strings.Save}"
                            Command="{Binding SaveCommand}"
                            FontSize="16"
                            FontWeight="Bold"/>

                    <Border Background="#FFEBEE" CornerRadius="4" Margin="0,16,0,0">
                        <TextBlock Margin="10"
                                   Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding StatusMessage}"
                                   FontWeight="Medium"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
