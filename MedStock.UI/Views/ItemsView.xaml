<UserControl x:Class="MedStock.UI.Views.ItemsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:MedStock.UI.Resources"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryDarkBrush}"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Padding" Value="0,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20" Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="1.2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Border Width="5" Height="25" Background="{StaticResource PrimaryBrush}" CornerRadius="2" Margin="0,0"/>
            <TextBlock Text="{x:Static res:Strings.Items_Title}" 
                       FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}" Margin="10,0,0,0"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" CornerRadius="10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#DDDDDD" BlurRadius="10" Opacity="0.4"/>
                </Border.Effect>
                <DockPanel Margin="15">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Height="38" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                 Tag="بحث عن مادة..." VerticalContentAlignment="Center" Padding="10,0"/>

                        <Button Grid.Column="1" Margin="10,0,0,0" Width="90" Height="38" Content="{x:Static res:Strings.Search}" 
                                Command="{Binding RefreshCommand}" Background="{StaticResource SecondaryBrush}"/>

                        <Button Grid.Column="2" Margin="10,0,0,0" Width="100" Height="38" Content="{x:Static res:Strings.Add}" 
                                Command="{Binding NewCommand}" Background="{StaticResource SuccessBrush}"/>
                    </Grid>

                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,15,0,0" HorizontalAlignment="Left">
                        <Button Width="100" Height="34" Content="{x:Static res:Strings.Edit}" 
                                Command="{Binding EditCommand}" Background="{StaticResource PrimaryBrush}"/>

                        <Button Margin="10,0,0,0" Width="100" Height="34" Content="تعطيل/تفعيل" 
                                Command="{Binding ToggleActiveCommand}" Background="Orange" Foreground="White"/>

                        <Button Margin="10,0,0,0" Width="100" Height="34" Content="حذف" 
                                Command="{Binding DeleteCommand}" Background="{StaticResource DangerBrush}"/>
                    </StackPanel>
                    <Grid DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="السابق" Command="{Binding PrevPageCommand}" 
                Width="80" Margin="5,0"/>

                            <Border Background="#F5F5F5" CornerRadius="4" Margin="10,0" Padding="15,5">
                                <TextBlock Text="{Binding PageInfo}" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Border>

                            <Button Content="التالي" Command="{Binding NextPageCommand}" 
                Width="80" Margin="5,0"/>
                        </StackPanel>
                    </Grid>
                    <DataGrid ItemsSource="{Binding Rows}" 
                              SelectedItem="{Binding Selected, Mode=TwoWay}" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              CanUserAddRows="False" 
                              GridLinesVisibility="Horizontal" 
                              HorizontalGridLinesBrush="#F0F0F0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{x:Static res:Strings.Name}" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="{x:Static res:Strings.Sku}" Binding="{Binding Sku}" Width="110"/>
                            <DataGridTextColumn Header="وحدة" Binding="{Binding UnitOfMeasure}" Width="80"/>
                            <DataGridTextColumn Header="إعادة طلب" Binding="{Binding ReorderLevel , StringFormat='{}{0:0.##}'}" Width="90"/>
                            <DataGridTextColumn Header="الرصيد الكلي" Binding="{Binding TotalQuantity , StringFormat='{}{0:0.##}'}" Width="90"/>
                            <DataGridCheckBoxColumn Header="نشط" Binding="{Binding IsActive}" Width="60"/>
                        </DataGrid.Columns>
                        
                    </DataGrid>
                    
                </DockPanel>
                
            </Border>

            <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" CornerRadius="10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#DDDDDD" BlurRadius="10" Opacity="0.4"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="{x:Static res:Strings.Edit}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text=" / إضافة" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                        </StackPanel>

                        <TextBlock Text="{x:Static res:Strings.Name}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                        <TextBox Height="38" Text="{Binding NameText, UpdateSourceTrigger=PropertyChanged}"/>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{x:Static res:Strings.Sku}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBox Height="38" Text="{Binding SkuText, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="وحدة القياس" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBox Height="38" Text="{Binding UnitOfMeasureText, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="حد إعادة الطلب" Foreground="{StaticResource TextSecondaryBrush }" Margin="0,0,0,5"/>
                                <TextBox Height="38" Text="{Binding ReorderLevelText,StringFormat='{}{0:0.##}', UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="الحد الأدنى" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                                <TextBox Height="38" Text="{Binding MinStockText,StringFormat='{}{0:0.##}', UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Margin="0,12,0,5" Text="الوصف" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox Height="70" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" 
                                 Text="{Binding DescriptionText, UpdateSourceTrigger=PropertyChanged}" Padding="5"/>

                        <CheckBox Margin="0,15,0,0" IsChecked="{Binding IsActive}" Content="{x:Static res:Strings.Active}" VerticalContentAlignment="Center"/>

                        <Button Margin="0,25,0,0" Height="45" Content="{x:Static res:Strings.Save}" Command="{Binding SaveCommand}" FontSize="16" FontWeight="Bold" Background="{StaticResource PrimaryBrush}" Foreground="White"/>

                        <TextBlock Margin="0,15,0,0" Foreground="Crimson" TextWrapping="Wrap" Text="{Binding StatusMessage}" TextAlignment="Center"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}" CornerRadius="10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" BlurRadius="10" Opacity="0.4"/>
            </Border.Effect>
            <DockPanel Margin="15">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <Border Width="3" Height="18" Background="{StaticResource SecondaryBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="تفاصيل الأرصدة (Batches)" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}"/>
                </StackPanel>

                <DataGrid ItemsSource="{Binding Batches}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم التشغيلة (Batch)" Binding="{Binding BatchCode}" Width="*"/>
                        <DataGridTextColumn Header="تاريخ الانتهاء" Binding="{Binding ExpiryDate, StringFormat=yyyy/MM/dd}" Width="150"/>
                        <DataGridTextColumn Header="الكمية الحالية" Binding="{Binding CurrentQty , StringFormat='{}{0:0.##}'}" Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="الموقع" Binding="{Binding LocationCode}" Width="130"/>
                        <DataGridTextColumn Header="سعر الشراء" Binding="{Binding UnitCost, StringFormat='{}{0:C0}'}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Row="5" Margin="0,10,0,0" Padding="8,5" Background="#E9ECEF" CornerRadius="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="الحالة: " FontWeight="SemiBold" Foreground="#495057"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#495057"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>