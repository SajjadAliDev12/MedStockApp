<UserControl x:Class="MedStock.UI.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:MedStock.UI.Resources" 
             FlowDirection="RightToLeft">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Border Width="400" 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center"
                Background="{StaticResource SurfaceBrush}" 
                CornerRadius="15" 
                Padding="30"
                BorderThickness="1"
                BorderBrush="{StaticResource BorderBrush}">

            <Border.Effect>
                <DropShadowEffect Color="#CCCCCC" BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
            </Border.Effect>

            <StackPanel>
                <Border Width="70" Height="70" 
                        Background="{StaticResource PrimaryBrush}" 
                        CornerRadius="35" 
                        Margin="0,0,0,20">
                    <TextBlock Text="M" Foreground="White" 
                               FontSize="35" FontWeight="Bold" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="{x:Static res:Strings.Login_Title}" 
                           FontSize="26" FontWeight="Bold" 
                           Foreground="{StaticResource PrimaryDarkBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <TextBlock Text="{x:Static res:Strings.Username}" 
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           Margin="0,0,0,8"/>
                <TextBox x:Name="txtuserName" Height="42" 
                         FontSize="16"
                         VerticalContentAlignment="Center"
                         Padding="10,0"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="{x:Static res:Strings.Password}" 
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           Margin="0,20,0,8"/>
                <PasswordBox x:Name="Pwd" Height="42" 
                             FontSize="16"
                             VerticalContentAlignment="Center" 
                             Padding="10,0"/>

                <Button Margin="0,35,0,0" 
                        Height="48" 
                        Content="{x:Static res:Strings.Login_Button}"
                        Click="Login_Click" 
                        IsDefault="True"
                        FontSize="18" 
                        FontWeight="Bold"
                        Cursor="Hand"/>

                <Border Background="#FFF1F0" CornerRadius="5" Margin="0,20,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <TextBlock Text="{Binding ErrorMessage}" 
                               Foreground="{StaticResource DangerBrush}"
                               TextWrapping="Wrap" 
                               Padding="10"
                               FontSize="13"
                               TextAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>