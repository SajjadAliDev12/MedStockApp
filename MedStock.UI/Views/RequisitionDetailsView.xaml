<UserControl x:Class="MedStock.UI.Views.RequisitionDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:MedStock.UI.Resources"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryDarkBrush}"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Padding" Value="0,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20" Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <Button DockPanel.Dock="Left" 
            Command="{Binding BackCommand}" 
            Width="110" Height="36"
            Content="← رجوع للقائمة" 
            Background="Transparent" 
            Foreground="{StaticResource PrimaryBrush}"
            BorderBrush="{StaticResource PrimaryBrush}"
            BorderThickness="1"
            FontWeight="SemiBold"
            Cursor="Hand"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="5" Height="25" Background="{StaticResource PrimaryBrush}" CornerRadius="2" Margin="0,0,10,0"/>

                <TextBlock Text="{Binding DetailsTitle}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}"/>

                <TextBlock Text="{Binding RequisitionNo}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}" Margin="10,0,0,0"/>
            </StackPanel>

            <Border HorizontalAlignment="Right" Padding="15,5" CornerRadius="15" Background="#E0F2F1" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource PrimaryBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding Status}" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </DockPanel>

        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="15" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" BlurRadius="10" Opacity="0.4"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding DeptLabel}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                    <ComboBox Height="38" ItemsSource="{Binding Departments}" SelectedItem="{Binding SelectedDepartment}" DisplayMemberPath="DepartmentName"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="ملاحظات الطلب العامة" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                    <TextBox Height="38" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Padding="10,0"/>
                </StackPanel>

                <Button Grid.Column="4" Height="38" Content="حفظ الرأس" VerticalAlignment="Bottom"
                        Command="{Binding SaveHeaderCommand}" Background="{StaticResource BackgroundBrush}"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}" CornerRadius="10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" BlurRadius="10" Opacity="0.4"/>
            </Border.Effect>
            <DataGrid Margin="10" ItemsSource="{Binding Lines}" SelectedItem="{Binding SelectedLine}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="المادة" Binding="{Binding ItemName}" Width="*"/>
                    <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="120"/>
                    <DataGridTextColumn Header="المطلوب" Binding="{Binding RequestedQty , StringFormat='{}{0:0.##}'}" Width="100"/>
                    <DataGridTextColumn Header="المصروف" Binding="{Binding FulfilledQty , StringFormat='{}{0:0.##}'}" Width="100"/>
                    <DataGridTextColumn Header="المتبقي" Binding="{Binding RemainingQty , StringFormat='{}{0:0.##}'}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="ملاحظات السطر" Binding="{Binding Notes}" Width="200"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="6" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="15" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="110"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="اختر المادة" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <ComboBox Height="38" ItemsSource="{Binding ItemsLookup}" SelectedItem="{Binding SelectedItem, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="Name" IsEditable="True"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="الكمية" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox Height="38" Text="{Binding QtyText,StringFormat='{}{0:0.##}', UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" TextAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="ملاحظات" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox Height="38" Text="{Binding LineNotes, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Padding="5,0"/>
                    </StackPanel>

                    <Button Grid.Column="6" Height="38" Content="حفظ المادة" VerticalAlignment="Bottom" Command="{Binding AddLineCommand}" Background="{StaticResource SuccessBrush}"/>
                    <Button Grid.Column="8" Height="38" Content="حذف المادة" VerticalAlignment="Bottom" Command="{Binding RemoveLineCommand}" Background="{StaticResource DangerBrush}"/>
                </Grid>

                <Separator Margin="0,15" Background="{StaticResource BorderBrush}"/>

                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button Width="100" Height="40" Content="إرسال" Command="{Binding SubmitCommand}" Background="{StaticResource PrimaryBrush}"/>
                        <Button Width="100" Height="40" Content="اعتماد" Command="{Binding ApproveCommand}" Background="{StaticResource SuccessBrush}" Margin="10,0,0,0"/>
                        <Button Width="100" Height="40" Content="رفض" Command="{Binding RejectCommand}" Background="{StaticResource DangerBrush}" Margin="10,0,0,0"/>
                        <Button Width="100" Height="40" Content="إلغاء" Command="{Binding CancelCommand}" Background="#757575" Margin="10,0,0,0"/>
                    </StackPanel>

                    <Button DockPanel.Dock="Right" Width="160" Height="40" Content="صرف السطر المحدد" Command="{Binding FulfillLineCommand}" Background="#0277BD" HorizontalAlignment="Right"/>

                    <TextBlock VerticalAlignment="Center" Margin="20,0" Foreground="Crimson" FontWeight="SemiBold" Text="{Binding StatusMessage}" TextWrapping="Wrap"/>
                </DockPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>