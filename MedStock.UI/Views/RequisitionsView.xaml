<UserControl x:Class="MedStock.UI.Views.RequisitionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:MedStock.UI.Resources"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryDarkBrush}"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Padding" Value="0,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20" Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Border Width="5" Height="25" Background="{StaticResource PrimaryBrush}" CornerRadius="2" Margin="0,0,10,0"/>
            <TextBlock Text="{Binding TitleLabel}" 
                       FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}"/>
        </StackPanel>

        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" BlurRadius="10" Opacity="0.4"/>
            </Border.Effect>
            <Grid Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="الحالة" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                    <ComboBox Height="38" ItemsSource="{Binding Statuses}" SelectedItem="{Binding SelectedStatus}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="{Binding DeptLabel}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                    <ComboBox Height="38" ItemsSource="{Binding Departments}" SelectedItem="{Binding SelectedDepartment}" DisplayMemberPath="DepartmentName"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="بحث (رقم الطلب / ملاحظات)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                    <TextBox Height="38" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Padding="10,0"/>
                </StackPanel>

                <Button Grid.Column="6" Width="100" Height="38" Content="تحديث" VerticalAlignment="Bottom"
                        Command="{Binding RefreshCommand}" Background="{StaticResource SecondaryBrush}"/>

                <Button Grid.Column="8" Width="120" Height="38" Content="إنشاء طلب" VerticalAlignment="Bottom"
                        Command="{Binding CreateDraftCommand}" Background="{StaticResource SuccessBrush}"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}" CornerRadius="10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" BlurRadius="10" Opacity="0.4"/>
            </Border.Effect>
            <DataGrid Margin="10" ItemsSource="{Binding Requisitions}" SelectedItem="{Binding SelectedRequisition}" 
                      AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="رقم الطلب" Binding="{Binding RequisitionNo}" Width="140"/>

                    <DataGridTextColumn Header="{Binding DataContext.DeptLabel, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                        Binding="{Binding DepartmentName}" Width="*"/>

                    <DataGridTemplateColumn Header="الحالة" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Status}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="تاريخ الطلب" Binding="{Binding RequestDate, StringFormat=yyyy/MM/dd HH:mm}" Width="160"/>
                    <DataGridTextColumn Header="بواسطة" Binding="{Binding RequestedBy}" Width="150"/>
                    <DataGridTextColumn Header="المعتمد" Binding="{Binding ApprovedBy}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <DockPanel Grid.Row="6" Margin="0,15,0,0">
            <Button DockPanel.Dock="Left" Width="180" Height="42" Content="فتح تفاصيل الطلب" 
                    Command="{Binding OpenDetailsCommand}" FontSize="15" FontWeight="Bold"/>

            <Border Background="#FFF1F0" CornerRadius="5" Margin="20,0,0,0" Padding="15,5" HorizontalAlignment="Right">
                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource DangerBrush}" 
                           FontWeight="SemiBold" Text="{Binding StatusMessage}"/>
            </Border>
        </DockPanel>
    </Grid>
</UserControl>