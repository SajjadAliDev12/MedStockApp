<UserControl x:Class="MedStock.UI.Views.StockCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:MedStock.UI.Resources"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryDarkBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Padding" Value="0,2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F5F5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20" Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Border Width="5" Height="25" Background="{StaticResource PrimaryBrush}" CornerRadius="2" Margin="0,0,10,0"/>
            <TextBlock Text="بطاقة المادة (Stock Card)" 
                       FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}"/>
        </StackPanel>

        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" BlurRadius="10" Opacity="0.4"/>
            </Border.Effect>
            <Grid Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="المادة" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                    <ComboBox Height="38" 
                              ItemsSource="{Binding ItemsLookup}"
                              SelectedItem="{Binding SelectedItem}"
                              DisplayMemberPath="Name"
                              IsEditable="True"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="من تاريخ" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                    <DatePicker Height="38" SelectedDate="{Binding FromDate}" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="إلى تاريخ" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                    <DatePicker Height="38" SelectedDate="{Binding ToDate}" VerticalContentAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="6" Width="140" Height="42" VerticalAlignment="Bottom"
                        Content="عرض التقرير"
                        Command="{Binding GenerateCommand}"
                        Background="{StaticResource SecondaryBrush}"
                        FontSize="15" FontWeight="Bold"/>
            </Grid>
        </Border>

        <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}" CornerRadius="10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" BlurRadius="10" Opacity="0.4"/>
            </Border.Effect>
            <DataGrid Margin="10" 
                      ItemsSource="{Binding ReportRows}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#EEEEEE">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="التاريخ والوقت" Binding="{Binding Date, StringFormat='yyyy/MM/dd HH:mm'}" Width="150"/>
                    <DataGridTextColumn Header="رقم الحركة" Binding="{Binding TransactionNo}" Width="140"/>
                    <DataGridTextColumn Header="النوع" Binding="{Binding TransactionType}" Width="100"/>
                    <DataGridTextColumn Header="الجهة المرجعية" Binding="{Binding Reference}" Width="*"/>

                    <DataGridTextColumn Header="وارد (+)" Binding="{Binding InQty , StringFormat='{}{0:0.##}'}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="TextAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="صادر (-)" Binding="{Binding OutQty , StringFormat='{}{0:0.##}'}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="TextAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="الرصيد" Binding="{Binding Balance ,StringFormat='{}{0:0.##}'}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="ExtraBold"/>
                                <Setter Property="TextAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="5"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="التشغيلة" Binding="{Binding BatchCode}" Width="120"/>
                    <DataGridTextColumn Header="المستخدم" Binding="{Binding User}" Width="120"/>
                    <DataGridTextColumn Header="ملاحظات" Binding="{Binding Notes}" Width="180"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="6" Margin="0,15,0,0" Padding="12,8" Background="#F8F9FA" CornerRadius="6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="الحالة: " FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextPrimaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>