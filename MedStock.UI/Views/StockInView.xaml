<UserControl x:Class="MedStock.UI.Views.StockInView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:MedStock.UI.Resources"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryDarkBrush}"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Padding" Value="0,2"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20" Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Border Width="5" Height="25" Background="{StaticResource PrimaryBrush}" CornerRadius="2" Margin="0,0,10,0"/>
            <TextBlock Text="إدخال مخزني (شراء مواد)" 
                       FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}"/>
        </StackPanel>

        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" BlurRadius="10" Opacity="0.4"/>
            </Border.Effect>
            <Grid Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    
                </Grid.ColumnDefinitions>

                
                <StackPanel>
                    <TextBlock Text="المورد (Supplier)" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                    <ComboBox Height="38" 
                              ItemsSource="{Binding SuppliersLookup}"
                              SelectedItem="{Binding SelectedSupplier}"
                              DisplayMemberPath="Name"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="كود القسم (اختياري)" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                    <TextBox Height="38" Text="{Binding DepartmentIdText}" VerticalContentAlignment="Center" Padding="10,0"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="ملاحظات عامة على الإدخال" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                    <TextBox Height="38" Text="{Binding Notes}" VerticalContentAlignment="Center" Padding="10,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="4" Background="#F1F8E9" CornerRadius="10" BorderBrush="#C8E6C9" BorderThickness="1">
            <Grid Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.5*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="المادة" FontSize="11" FontWeight="SemiBold"/>
                    <ComboBox Height="36" 
                              ItemsSource="{Binding ItemsLookup}"
                              SelectedItem="{Binding SelectedItem}"
                              DisplayMemberPath="Name"
                              IsEditable="True"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="التشغيلة (Batch)" FontSize="11" FontWeight="SemiBold"/>
                    <TextBox Height="36" Text="{Binding NewLine.BatchCode}" VerticalContentAlignment="Center" Padding="5,0"/>
                </StackPanel>
                <StackPanel Grid.Column="10">
                    <TextBlock Text="الموقع (رف/خزانة)" FontSize="11" FontWeight="SemiBold"/>
                    <TextBox Height="36"
             Text="{Binding NewLine.LocationCode}"
             VerticalContentAlignment="Center"
             TextAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="الكمية" FontSize="11" FontWeight="SemiBold"/>
                    <TextBox Height="36" Text="{Binding NewLine.QtyText}" VerticalContentAlignment="Center" TextAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="6">
                    <TextBlock Text="التكلفة" FontSize="11" FontWeight="SemiBold"/>
                    <TextBox Height="36" Text="{Binding NewLine.UnitCostText}" VerticalContentAlignment="Center" TextAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="8">
                    <TextBlock Text="الانتهاء (YYYY-MM-DD)" FontSize="11" FontWeight="SemiBold"/>
                    <TextBox Height="36" Text="{Binding NewLine.ExpiryDateText}" VerticalContentAlignment="Center" TextAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="12" Width="100" Height="36" VerticalAlignment="Bottom"
                        Content="إضافة للجدول" 
                        Command="{Binding AddLineCommand}"
                        Background="{StaticResource SuccessBrush}"
                        FontWeight="Bold"/>
            </Grid>
        </Border>

        <Border Grid.Row="6" Background="{StaticResource SurfaceBrush}" CornerRadius="10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" BlurRadius="10" Opacity="0.4"/>
            </Border.Effect>
            <DataGrid Margin="10" 
                      ItemsSource="{Binding Lines}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#EEEEEE">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="كود المادة" Binding="{Binding ItemIdText}" Width="100"/>
                    <DataGridTextColumn Header="رقم التشغيلة" Binding="{Binding BatchCode}" Width="150"/>
                    <DataGridTextColumn Header="الكمية الواردة" Binding="{Binding QtyText , StringFormat='{}{0:0.##}'}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="تكلفة الوحدة" Binding="{Binding UnitCostText }" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="تاريخ الصلاحية" Binding="{Binding ExpiryDateText}" Width="150"/>

                    <DataGridTemplateColumn Header="إجراءات" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="حذف السطر" 
                                        Padding="10,2"
                                        Background="{StaticResource DangerBrush}"
                                        Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Padding="12,8" Background="#E3F2FD" CornerRadius="6" BorderBrush="#BBDEFB" BorderThickness="1" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="الحالة: " FontWeight="SemiBold" Foreground="{StaticResource InfoBrush}"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>
            </Border>

            <Button Grid.Column="1" Width="200" Height="45" 
                    Content="حفظ فاتورة الإدخال"
                    Command="{Binding SaveCommand}"
                    Background="{StaticResource PrimaryBrush}"
                    FontSize="16" FontWeight="Bold"/>
        </Grid>
    </Grid>
</UserControl>