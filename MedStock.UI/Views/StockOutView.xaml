<UserControl x:Class="MedStock.UI.Views.StockOutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
             mc:Ignorable="d" FlowDirection="RightToLeft"
             d:DesignHeight="700" d:DesignWidth="1100">



    <Grid Background="#F3F4F6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="20" Background="White" CornerRadius="8" >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Padding="15" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="طلبات الصرف الواردة (Needs Approval)" FontSize="16" FontWeight="Bold" Foreground="#1F2937"/>
                        <TextBlock Text="اضغط على زر 'صرف' لنقل البيانات للنموذج" FontSize="12" Foreground="#6B7280" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="1" ItemsSource="{Binding PendingRequests}" AutoGenerateColumns="False" 
                          IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم الطلب" Binding="{Binding RequisitionNo}" Width="100"/>
                        <DataGridTextColumn Header="القسم" Binding="{Binding DepartmentName}" Width="120"/>
                        <DataGridTextColumn Header="المادة" Binding="{Binding ItemName}" Width="*"/>
                        <DataGridTextColumn Header="مطلوب" Binding="{Binding RequestedQty , StringFormat='{}{0:0.##}'}" Width="60"/>
                        <DataGridTextColumn Header="متبقي" Binding="{Binding RemainingQty , StringFormat='{}{0:0.##}'}" Width="60" FontWeight="Bold"/>
                        <DataGridTemplateColumn Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="صرف ⬅" 
                                            Command="{Binding DataContext.SelectPendingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Background="#10B981" Foreground="White" BorderThickness="0" Padding="5"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Margin="0,20,20,20" Background="White" CornerRadius="8" Padding="20" >
            <ScrollViewer>
                <StackPanel>
                    <TextBlock Text="بيانات الصرف" FontSize="18" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,20"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15" HorizontalAlignment="Center">
                        <RadioButton Content="صرف يدوي (مباشر)" IsChecked="{Binding IsManualMode}" GroupName="Mode" Margin="10,0"/>
                        <RadioButton Content="مرتبط بطلب (Requisition)" IsChecked="{Binding IsManualMode, Converter={StaticResource InvertBoolConverter}}" GroupName="Mode" IsEnabled="False"/>
                    </StackPanel>

                    <TextBlock Text="المادة *" Foreground="#374151" Margin="0,10,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" 
          IsEditable="True" 
          StaysOpenOnEdit="True" 
          IsDropDownOpen="{Binding IsDropDownOpen, Mode=TwoWay}"
          Text="{Binding ItemSearchText, UpdateSourceTrigger=PropertyChanged}"
          ItemsSource="{Binding SearchResults}" 
          DisplayMemberPath="Name"
          SelectedItem="{Binding SelectedItem}"
          Height="40" VerticalContentAlignment="Center"/>
                        <Button Grid.Column="1" Content="🔍" Command="{Binding SearchItemCommand}" Width="40" Margin="5,0,0,0"/>
                    </Grid>
                    <TextBlock Text="اكتب 3 حروف للبحث" FontSize="11" Foreground="Gray" Margin="0,2,0,0"/>

                    <TextBlock Text="الكمية المراد صرفها *" Foreground="#374151" Margin="0,15,0,5"/>
                    <TextBox Text="{Binding Qty ,StringFormat='{}{0:0.##}'}" Height="40" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold" TextAlignment="Center" Background="#F9FAFB"/>

                    <TextBlock Text="القسم المستلم" Foreground="#374151" Margin="0,15,0,5"/>
                    <ComboBox ItemsSource="{Binding Departments}" DisplayMemberPath="DepartmentName" 
                              SelectedItem="{Binding SelectedDepartment}" Height="40"
                              IsEnabled="{Binding IsManualMode}"/>

                    <TextBlock Text="نوع الحركة" Foreground="#374151" Margin="0,15,0,5"/>
                    <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding ReasonCode}" Height="40" IsEnabled="{Binding IsManualMode}">
                        <ComboBoxItem Content="تلبية طلب (Req Fulfill)" Tag="REQ_FULFILL"/>
                        <ComboBoxItem Content="صرف مباشر (Dispense)" Tag="DISPENSE"/>
                        <ComboBoxItem Content="إتلاف منتهي (Expired)" Tag="EXPIRED"/>
                        <ComboBoxItem Content="إتلاف كسر (Damage)" Tag="DAMAGE"/>
                    </ComboBox>

                    <TextBlock Text="ملاحظات" Foreground="#374151" Margin="0,15,0,5"/>
                    <TextBox Text="{Binding Notes}" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                        <Button Content="مسح" Command="{Binding ClearCommand}" Width="80" Height="40" Background="Gray" Foreground="White" BorderThickness="0" Margin="10,0"/>
                        <Button Content="تأكيد الصرف" Command="{Binding SubmitCommand}" Width="140" Height="40" Background="#2563EB" Foreground="White" FontWeight="Bold" BorderThickness="0">
                            <Button.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="5" Opacity="0.2"/>
                            </Button.Effect>
                        </Button>
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="#DC2626" TextWrapping="Wrap" Margin="0,15,0,0" HorizontalAlignment="Center"/>

                    <ProgressBar IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" Height="2" Margin="0,10"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>