<UserControl x:Class="MedStock.UI.Views.StocktakesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:MedStock.UI.Resources"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryDarkBrush}"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Padding" Value="0,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20" Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="5" Height="25" Background="{StaticResource PrimaryBrush}" CornerRadius="2" Margin="0,0,10,0"/>
                <TextBlock Text="أرشيف الجرد المخزني" 
                           FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}"/>
            </StackPanel>

            <Button DockPanel.Dock="Left" 
                    HorizontalAlignment="Left" 
                    Width="180" Height="42"
                    Content="+ إنشاء جرد جديد" 
                    Command="{Binding CreateCommand}" 
                    Background="{StaticResource SuccessBrush}" 
                    Foreground="White" 
                    FontSize="15" 
                    FontWeight="Bold"
                    Cursor="Hand"/>
        </DockPanel>

        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#DDDDDD" BlurRadius="15" ShadowDepth="2" Opacity="0.4"/>
            </Border.Effect>

            <DockPanel Margin="10">
                <Grid DockPanel.Dock="Top" Margin="5,5,5,15">
                    <TextBlock Text="قائمة عمليات الجرد المسجلة في النظام" Foreground="{StaticResource TextSecondaryBrush}" FontStyle="Italic"/>
                </Grid>

                <DataGrid ItemsSource="{Binding Rows}" 
                          SelectedItem="{Binding SelectedRow}"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True" 
                          CanUserAddRows="False"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#EEEEEE"
                          BorderThickness="1"
                          BorderBrush="{StaticResource BorderBrush}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم الجرد" Binding="{Binding StocktakeNo}" Width="150"/>

                        <DataGridTextColumn Header="التاريخ" Binding="{Binding Date, StringFormat=yyyy/MM/dd}" Width="130"/>

                        <DataGridTemplateColumn Header="الحالة" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="8,2" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Status}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="أنشأ بواسطة" Binding="{Binding CreatedBy}" Width="150"/>

                        <DataGridTextColumn Header="ملاحظات" Binding="{Binding Notes}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <Button Content="تحديث القائمة" 
                        Command="{Binding RefreshCommand}" 
                        Width="130" Height="38"
                        Background="{StaticResource SecondaryBrush}"/>

                <Button Content="فتح التفاصيل / العد" 
                        Command="{Binding OpenDetailsCommand}" 
                        Width="180" Height="38" 
                        Margin="15,0,0,0"
                        Background="{StaticResource PrimaryBrush}"
                        FontWeight="Bold"/>
            </StackPanel>

            <Border Grid.Column="2" Padding="15,5" CornerRadius="5" Background="#FFF1F0" 
                    
                    BorderBrush="#FFCCC7" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠" Foreground="{StaticResource DangerBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>