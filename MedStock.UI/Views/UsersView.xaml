<UserControl x:Class="MedStock.UI.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:MedStock.UI.Resources"
             FlowDirection="RightToLeft">

    <UserControl.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryDarkBrush}"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Padding" Value="0,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20" Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
            <Border Width="5" Height="25" Background="{StaticResource PrimaryBrush}" CornerRadius="2" Margin="0,0,10,0"/>
            <TextBlock Text="إدارة المستخدمين والصلاحيات" 
                       FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryDarkBrush}"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1.35*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" CornerRadius="10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#DDDDDD" BlurRadius="10" Opacity="0.4"/>
                </Border.Effect>
                <DockPanel Margin="15">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Height="38" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                 Tag="بحث بالاسم..." VerticalContentAlignment="Center" Padding="10,0"/>
                        <Button Grid.Column="1" Margin="10,0,0,0" Width="90" Height="38" Content="بحث" 
                                Command="{Binding RefreshCommand}" Background="{StaticResource SecondaryBrush}"/>
                        <Button Grid.Column="2" Margin="10,0,0,0" Width="100" Height="38" Content="جديد" 
                                Command="{Binding NewCommand}" Background="{StaticResource SuccessBrush}"/>
                    </Grid>

                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,15,0,0" HorizontalAlignment="Left">
                        <Button Width="130" Height="34" Content="تجميد/تفعيل الحساب" 
                                Command="{Binding ToggleActiveCommand}" Background="{StaticResource DangerBrush}"/>
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding Rows}" SelectedItem="{Binding Selected}" 
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" 
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="اسم المستخدم" Binding="{Binding Username}" Width="120"/>
                            <DataGridTextColumn Header="الاسم الكامل" Binding="{Binding DisplayName}" Width="150"/>
                            <DataGridTextColumn Header="الأدوار الممنوحة" Binding="{Binding Roles}" Width="*"/>
                            <DataGridCheckBoxColumn Header="فعال" Binding="{Binding IsActive}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" CornerRadius="10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#DDDDDD" BlurRadius="10" Opacity="0.4"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="بيانات المستخدم" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,20"/>

                        <TextBlock Text="اسم الدخول (Username) *" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                        <TextBox Height="38" Text="{Binding UsernameText, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="الاسم الكامل *" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,5"/>
                        <TextBox Height="38" Text="{Binding DisplayNameText, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="الأدوار والصلاحيات (Roles)" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,5"/>
                        <Border Background="#F9F9F9" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="10" MaxHeight="150">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding AllRoles}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding RoleName}" IsChecked="{Binding IsSelected}" Margin="0,4" FontSize="13"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                        <TextBlock Text="كلمة المرور" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,15,0,5"/>
                        <TextBox Height="38" Text="{Binding PasswordText, UpdateSourceTrigger=PropertyChanged}" 
                                 ToolTip="أدخل كلمة مرور جديدة للتعيين أو التغيير"/>

                        <Button Margin="0,8,0,0" HorizontalAlignment="Left" Content="إعادة تعيين كلمة المرور" Width="160" Height="30"
                                Command="{Binding ResetPassCommand}" Background="{StaticResource InfoBrush}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsNewUser}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <CheckBox Margin="0,20,0,0" IsChecked="{Binding IsActive}" Content="الحساب فعال وقابل للدخول" VerticalContentAlignment="Center"/>

                        <Button Margin="0,30,0,0" Height="45" Content="حفظ بيانات المستخدم" 
                                Command="{Binding SaveCommand}" FontSize="16" FontWeight="Bold"/>

                        <TextBlock Margin="0,15,0,0" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" 
                                   Text="{Binding StatusMessage}" TextAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="4" Margin="0,15,0,0" Padding="12,8" Background="#F8F9FA" CornerRadius="6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="الحالة: " FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextPrimaryBrush}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>